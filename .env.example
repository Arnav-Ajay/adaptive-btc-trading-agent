# Environment variables for the Adaptive BTC Trading Agent
APP_ENV=development
LOG_LEVEL=INFO

# Innput API configuration
CONFIG_CACHE_PATH=config/config_cache.json
COINBASE_API_KEY=
COINBASE_API_SECRET=
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Trading configuration
TRADING_SYMBOL=BTC-USD
DATA_LAKE_PATH=data_lake
TRADING_LOOKBACK=500
MIN_CANDLES_REQUIRED=50
MAX_DATA_STALENESS_MINUTES=90
LOOP_INTERVAL_SECONDS=60
MAX_CYCLES=1
RUNTIME_SCHEDULE_MINUTES=30
RUNTIME_DECISION_OFFSET_MINUTES=2
PAPER_TRADING_ENABLED=true
PAPER_STATE_PATH=data_lake/state/paper_trade/paper_broker_state.json
PAPER_TRADE_LOG_PATH=data_lake/state/paper_trade/paper_trade_ledger.jsonl
PAPER_CYCLE_LOG_PATH=data_lake/state/paper_trade/paper_cycle_log.jsonl
PAPER_SNAPSHOT_PATH=data_lake/state/paper_trade/paper_portfolio_snapshot.json
PAPER_DECISION_TRACE_PATH=data_lake/state/paper_trade/paper_decision_trace.jsonl

# Ingestion configuration
INGESTION_PROVIDER=coinbase
INGESTION_ENABLED=true
INGESTION_INTERVAL=1m
INGESTION_SCHEDULE_MINUTES=30
INGESTION_OVERLAP_MINUTES=90
INGESTION_FETCH_LIMIT=300
INGESTION_MAX_RETRIES=3
INGESTION_RETRY_DELAY_SECONDS=5
INGESTION_STATE_PATH=data_lake/state/ingestion/coinbase_btc_usd_1m.json
INGESTION_HEALTH_MAX_STALENESS_MINUTES=75

# Telegram configuration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gmail configuration
GMAIL_ENABLED=false
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=

# OpenAI configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_BASE_URL=https://api.openai.com/v1/responses
OPENAI_TIMEOUT_SECONDS=20
LLM_ENABLED=false
LLM_ALLOW_BLOCKING=true
LLM_MIN_SIZE_MULTIPLIER=0.5
LLM_MAX_SIGNALS_PER_REVIEW=8

# Hybrid pullback selector configuration
HYBRID_DCA_ENABLED_IN_BULLISH=true
HYBRID_DCA_ENABLED_IN_SIDEWAYS=false
HYBRID_DCA_ENABLED_IN_WEAKENING_BULL=false
HYBRID_DCA_ENABLED_IN_BEARISH=false
HYBRID_DCA_SUPPRESSED_BY_PULLBACK_SIGNAL=true
HYBRID_DCA_SUPPRESSED_WITH_OPEN_PULLBACK_POSITION=true
HYBRID_BULLISH_DCA_MAX_ALLOCATION_PERCENT=20
